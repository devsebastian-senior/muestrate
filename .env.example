# ─────────────────────────────────────────────────────────────
#  MUÉSTRATE — variables de entorno
#  Copia este archivo a .env.local y rellena los valores.
#  NUNCA commitees .env.local (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Supabase (DB + Auth) ──
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # SOLO server. Nunca exponer al cliente.

# Connection string para Drizzle (Project Settings → Database → Connection string → "Transaction" pooler)
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres"

# ── Stripe (pago global) ──
# Dashboard → Developers → API keys (usa claves de TEST para empezar)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."           # de: stripe listen / endpoint
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Bunny Stream (video) ──
# Bunny.net → Stream → Library
BUNNY_STREAM_LIBRARY_ID="123456"
BUNNY_STREAM_API_KEY="xxxxxxxx-xxxx-xxxx"   # AccessKey de la Video Library
BUNNY_STREAM_CDN_HOSTNAME="vz-xxxxxxxx.b-cdn.net"
BUNNY_STREAM_TOKEN_AUTH_KEY="xxxxxxxx"      # Token Authentication key (para URLs firmadas)

# ── Resend (email transaccional) ──
RESEND_API_KEY="re_..."
EMAIL_FROM="Muéstrate <acceso@tudominio.com>"

# ── WhatsApp Cloud API (opcional, Fase 3) ──
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
